{
  "name": "@saptools/cf-explorer",
  "version": "0.2.3",
  "description": "Explore files inside SAP BTP Cloud Foundry app containers with safe read-only SSH workflows.",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "cf-explorer": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --max-warnings 0",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "sap",
    "cloud-foundry",
    "btp",
    "ssh",
    "files",
    "explorer",
    "cli",
    "saptools"
  ],
  "author": "Dong Tran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongitran/saptools.git",
    "directory": "packages/cf-explorer"
  },
  "homepage": "https://github.com/dongitran/saptools/tree/main/packages/cf-explorer#readme",
  "bugs": {
    "url": "https://github.com/dongitran/saptools/issues"
  },
  "dependencies": {
    "@saptools/cf-sync": "^0.4.3",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.3.0",
    "vitest": "^3.0.0"
  }
}
