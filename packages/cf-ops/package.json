{
  "name": "@saptools/cf-ops",
  "version": "0.1.0",
  "description": "Operate SAP BTP Cloud Foundry apps with safe restart and scaling workflows",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "cf-ops": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests *.ts --ignore-pattern tests/e2e/fixtures/fake-cf.mjs",
    "test:unit": "vitest run --coverage",
    "check": "pnpm cspell && pnpm lint && pnpm typecheck && pnpm test:unit && pnpm build && pnpm test:e2e",
    "cspell": "cspell --config ../../.cspell.json \"src/**/*.ts\" \"tests/**/*.ts\" \"tests/**/*.mjs\" \"*.ts\" README.md package.json",
    "test:e2e": "playwright test",
    "test:e2e:fake": "playwright test tests/e2e/cf-ops.e2e.ts"
  },
  "keywords": [
    "sap",
    "cloud-foundry",
    "btp",
    "operations",
    "scale",
    "restart",
    "cli",
    "saptools"
  ],
  "author": "Dong Tran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongitran/saptools.git",
    "directory": "packages/cf-ops"
  },
  "homepage": "https://github.com/dongitran/saptools/tree/main/packages/cf-ops#readme",
  "bugs": {
    "url": "https://github.com/dongitran/saptools/issues"
  },
  "dependencies": {
    "commander": "13.1.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@vitest/coverage-v8": "3.2.4",
    "tsup": "8.5.1",
    "vitest": "3.2.4"
  }
}
