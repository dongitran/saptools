{
  "name": "@saptools/cf-sync",
  "version": "0.3.0",
  "description": "Sync SAP BTP Cloud Foundry structure (region/org/space/app) to a local JSON file",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "cf-sync": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ignore-pattern tests/e2e/fixtures/fake-cf.mjs",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "sap",
    "cloud-foundry",
    "btp",
    "cli",
    "saptools"
  ],
  "author": "Dong Tran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongitran/saptools.git",
    "directory": "packages/cf-sync"
  },
  "homepage": "https://github.com/dongitran/saptools/tree/main/packages/cf-sync#readme",
  "bugs": {
    "url": "https://github.com/dongitran/saptools/issues"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.3.0",
    "vitest": "^3.0.0"
  }
}
