{
  "name": "@saptools/sharepoint-excel",
  "version": "0.1.0",
  "description": "Create, read, and update SharePoint-hosted Excel workbooks through Microsoft Graph with safe local credential profiles",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "saptools-sharepoint-excel": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ignore-pattern tests/e2e/fixtures/fake-graph.mjs --max-warnings 0",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:fake": "playwright test tests/e2e/sharepoint-excel.e2e.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm build && pnpm test:unit && pnpm test:e2e:fake"
  },
  "keywords": [
    "sap",
    "sharepoint",
    "excel",
    "xlsx",
    "microsoft-graph",
    "office365",
    "cli",
    "saptools"
  ],
  "author": "Dong Tran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongitran/saptools.git",
    "directory": "packages/sharepoint-excel"
  },
  "homepage": "https://github.com/dongitran/saptools/tree/main/packages/sharepoint-excel#readme",
  "bugs": {
    "url": "https://github.com/dongitran/saptools/issues"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "commander": "^13.0.0",
    "exceljs": "^4.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.3.0",
    "vitest": "^3.0.0"
  }
}
