{
  "name": "@saptools/cf-event-mesh",
  "version": "0.1.0",
  "description": "Listen and publish messages to SAP Event Mesh from SAP BTP Cloud Foundry",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "cf-event-mesh": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "sap",
    "cloud-foundry",
    "btp",
    "cli",
    "saptools",
    "event-mesh",
    "amqp"
  ],
  "author": "Dong Tran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongitran/saptools.git",
    "directory": "packages/cf-event-mesh"
  },
  "dependencies": {
    "@sap/xb-msg-amqp-v100": "^0.9.58",
    "commander": "^13.0.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.3.0",
    "vitest": "^3.0.0"
  }
}
