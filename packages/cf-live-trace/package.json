{
  "name": "@saptools/cf-live-trace",
  "version": "0.1.6",
  "description": "Inject a runtime HTTP trace hook into SAP BTP Cloud Foundry Node.js apps and stream request/response events from the CLI.",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "cf-live-trace": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ignore-pattern tests/e2e/fixtures/fake-cf.mjs --ignore-pattern tests/e2e/fixtures/inspectable-app.mjs",
    "cspell": "cspell --config ../../.cspell.json \"src/**/*.ts\" \"tests/**/*.ts\" README.md package.json",
    "test:unit": "vitest run --coverage",
    "test:e2e": "pnpm build && playwright test",
    "check": "pnpm cspell && pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:e2e"
  },
  "keywords": [
    "sap",
    "cloud-foundry",
    "btp",
    "trace",
    "http",
    "request",
    "response",
    "node-inspector",
    "cli",
    "saptools"
  ],
  "author": "Dong Tran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongitran/saptools.git",
    "directory": "packages/cf-live-trace"
  },
  "homepage": "https://github.com/dongitran/saptools/tree/main/packages/cf-live-trace#readme",
  "bugs": {
    "url": "https://github.com/dongitran/saptools/issues"
  },
  "dependencies": {
    "@saptools/cf-inspector": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.3.0",
    "vitest": "^3.0.0"
  }
}
