{
  "name": "@saptools/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @saptools/* npm packages",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dongitran/saptools.git"
  },
  "homepage": "https://github.com/dongitran/saptools#readme",
  "bugs": {
    "url": "https://github.com/dongitran/saptools/issues"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "cspell": "cspell \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "check": "pnpm cspell && pnpm lint && pnpm typecheck && pnpm test:unit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "cspell": "^9.7.0",
    "eslint": "^10.1.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unicorn": "^58.0.0",
    "husky": "^9.1.7",
    "turbo": "^2.3.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.0"
  },
  "packageManager": "pnpm@10.15.1"
}
